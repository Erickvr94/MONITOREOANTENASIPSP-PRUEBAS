# Números de WhatsApp para notificaciones (formato internacional sin +)
# Separados por coma si son múltiples números
# Ejemplo: 56912345678,56987654321

WHATSAPP_NUMBERS=56912345678

# Intervalo de monitoreo en milisegundos (30000 = 30 segundos)
MONITOR_INTERVAL=30000

# Número máximo de errores consecutivos antes de marcar como OFFLINE
MAX_ERROR_COUNT=3
