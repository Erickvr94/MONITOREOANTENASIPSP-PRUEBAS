# Intervalo de monitoreo en milisegundos (60000 = 60 segundos)
MONITOR_INTERVAL=60000

# Número máximo de verificaciones por ciclo antes de marcar como OFFLINE
MAX_ERROR_COUNT=5

# Intervalo de monitoreo SNMP en milisegundos (30000 = 30 segundos)
SNMP_INTERVAL=30000

# Puerto del servidor WebSocket/HTTP
WS_PORT=3000

# Nivel de log (trace, debug, info, warn, error)
LOG_LEVEL=info

# Conexión a MongoDB
MONGODB_URI=mongodb://localhost:27017/monitoreo

# JWT
JWT_SECRET=changeme
JWT_EXPIRES_IN=8h
